NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-actions-only
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=chaixpress
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production defaults to database-only behavior. Enable only for an intentional demo deployment.
ENABLE_DEMO_DATA=false

# Use international format without plus signs for wa.me links.
NEXT_PUBLIC_DEMO_WHATSAPP_NUMBER=971551150068

# Protects cron routes (e.g. /api/cron/daily-summary). The route rejects any
# request whose Authorization header is not `Bearer ${CRON_SECRET}`, and fails
# closed if this is unset. Set the same value in the Vercel project settings.
CRON_SECRET=your-cron-secret

# Google Gemini key used for menu extraction, the daily-summary narration, and
# admin AI menu-item image generation. If unset, the daily summary still sends —
# it falls back to a deterministic template built from the same numbers — and the
# "Generate AI Image" button reports that the feature isn't configured.
# GOOGLE_AI_API_KEY is accepted as an alias.
GEMINI_API_KEY=your-gemini-key

# Model used for admin AI menu-item image generation (server-side only; the key
# above is never sent to the browser). Configurable so we never hardcode a paid
# model; defaults to gemini-2.5-flash-image when unset. GOOGLE_IMAGE_MODEL is
# accepted as an alias.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Signs customer-login link + session tokens (src/lib/customer-auth). Must be
# >= 32 chars; generate with: openssl rand -base64 48. The app throws on first
# use of the customer-auth helpers if this is missing or too short.
CUSTOMER_AUTH_SECRET=your-customer-auth-secret-min-32-chars

# Standards-based Web Push for customer order-status updates. Generate the
# VAPID pair with `npx web-push generate-vapid-keys`; the public key is safe to
# expose to subscribed browsers, while the private key remains server-only.
# PUSH_AUTH_SECRET may be omitted to reuse CUSTOMER_AUTH_SECRET for the signed,
# order-specific subscription authorization cookie.
WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_SUBJECT=mailto:support@example.com
# PUSH_AUTH_SECRET=optional-separate-secret-min-32-chars

# WhatsApp Cloud API — inbound webhook (src/app/api/whatsapp/webhook) that mints
# the customer-login deep link. All optional: until set, webhook verification
# returns 403 and inbound messages are acknowledged without a reply.
#   VERIFY_TOKEN    — any string; enter the same value in Meta's webhook config.
#   APP_SECRET      — Meta app secret; verifies the X-Hub-Signature-256 header.
#   ACCESS_TOKEN    — Cloud API token used to send the reply (temp token = 24h).
#   PHONE_NUMBER_ID — id of the sending number (from WhatsApp → API Setup).
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=your-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
