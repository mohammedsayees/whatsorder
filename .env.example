NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-actions-only
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=chaixpress
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production defaults to database-only behavior. Enable only for an intentional demo deployment.
ENABLE_DEMO_DATA=false

# Use international format without plus signs for wa.me links.
NEXT_PUBLIC_DEMO_WHATSAPP_NUMBER=971551150068

# Protects cron routes (e.g. /api/cron/daily-summary). The route rejects any
# request whose Authorization header is not `Bearer ${CRON_SECRET}`, and fails
# closed if this is unset. Set the same value in the Vercel project settings.
CRON_SECRET=your-cron-secret

# Google Gemini key used for menu extraction and the daily-summary narration.
# If unset, the daily summary still sends — it falls back to a deterministic
# template built from the same numbers.
GEMINI_API_KEY=your-gemini-key

# Signs customer-login link + session tokens (src/lib/customer-auth). Must be
# >= 32 chars; generate with: openssl rand -base64 48. The app throws on first
# use of the customer-auth helpers if this is missing or too short.
CUSTOMER_AUTH_SECRET=your-customer-auth-secret-min-32-chars
